# Supabase — kopiraj to datoteko v ".env" in prilepi svoja javna client podatka.
# Najdeš ju v Supabase: Project Settings → API.
# Datoteka ".env" je v .gitignore in se NE shrani v git.
#
# VITE_* vrednosti gredo v browser bundle, zato sem nikoli ne daj:
# - service_role key
# - ANTHROPIC_API_KEY / GEMINI_API_KEY
# - Stripe secret, JWT secret, ali drugih server-side skrivnosti.

VITE_SUPABASE_URL=https://TVOJ_PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=TVOJ_ANON_KEY
